class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        int n=nums.length;
        int l=0;
        int product=1;
        int ans=0;

        for(int i=0;i<n;i++){
            product*=nums[i];

            while(l<=i && product >= k){
                product=product/nums[l];
                l++;
            }
            ans+=i-l+1;
        }
        return ans;
        
    }
}
