class Solution {
    public int pivotIndex(int[] nums) {

        int l=0;
        int r=nums.length-1;
        int sum=0;

        for(int j:nums){
            sum+=j;

        }

        for(int i=0;i<nums.length;i++){
            r=sum-l-nums[i];

            if(r==l) return i;


            l+=nums[i];
        }
        return -1;
        
    }
}
