class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {

        int j=0;

        int[] nums3=new int[m+n];
        int k=0;

        for(int i=0;i<m;i++){
            nums3[k++]=nums1[i];
        }

        for(int i=0;i<n;i++){
            nums3[k++]=nums2[i];
        }


        for(int i=0;i<nums3.length;i++){
            nums1[i]=nums3[j++];
        }
        Arrays.sort(nums1);
        
        
    }
}
