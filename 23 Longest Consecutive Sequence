class Solution {
    public int longestConsecutive(int[] nums) {

        Arrays.sort(nums);
        int count=1;
        int n=nums.length;
        int maxi=0;
        if(n==0) return maxi;
        maxi=Math.max(maxi,count);
        for(int i=0;i<n-1;i++){
            if(nums[i]==nums[i+1]) continue;
            else if(nums[i]+1==nums[i+1]) count++;
            else count=1;
            maxi=Math.max(maxi,count);

           
        }
        return maxi;
        
    }
}
