class Solution {
    public int numSubarrayBoundedMax(int[] nums, int left, int right) {

        int start=-1,end=-1,res=0;

        for(int i=0;i<nums.length;i++){
            if(nums[i]>right){
                end=i;
            }
            if(nums[i]>=left){
                start=i;
            }
            res+=start-end;
        }
        return res;
        
    }
}
