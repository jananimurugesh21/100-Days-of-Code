class Solution {
    public boolean searchMatrix(int[][] matrix, int target) {

        for(int[] i:matrix){
             int l=0,r=i.length-1;

            while(l<=r){
                
                int mid=(l+r)/2;

                if(i[mid]==target) return true;
                else if(i[mid]>target) r=mid-1;
                else l=mid+1;

            }
            
        }

       

        
        return false;
        
    }
}

