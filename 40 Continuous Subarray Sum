class Solution {
    public boolean checkSubarraySum(int[] nums, int k) {
        HashMap<Integer,Integer> h=new HashMap<>();
        h.put(0,-1);
        int total=0;

        for(int i=0;i<nums.length;i++){
            total+=nums[i];
            int r=total%k;
            if(h.containsKey(r)){
                if(i-h.get(r)>1){
                return true;

            }
        }else{
            h.put(r,i);
        }
        }
        return false;
    }
}
